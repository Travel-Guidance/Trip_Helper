# ── 항공 API ──────────────────────────────────────────────
DUFFEL_ACCESS_TOKEN=duffel_test_your_key

# ── 숙박 API ──────────────────────────────────────────────
HOTELBEDS_API_KEY=your_hotelbeds_api_key
HOTELBEDS_API_SECRET=your_hotelbeds_secret

# ── 이메일 ────────────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_sender_email

EMAIL_NAVER_USER=your_naver_email
EMAIL_NAVER_PASS=your_naver_smtp_password
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_SECURE=true

# ── 지도 ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Gemini AI ─────────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key

# ── MySQL (Docker) ────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=tripuser
MYSQL_PASSWORD=trippassword
MYSQL_DATABASE=trip_helper

# ── Redis (Docker) ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Qdrant Vector DB (Docker) ─────────────────────────────
QDRANT_URL=http://localhost:6333

# ── 서버 ──────────────────────────────────────────────────
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
