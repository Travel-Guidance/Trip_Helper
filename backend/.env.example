# Flight booking API
DUFFEL_ACCESS_TOKEN=duffel_test_your_key

# Accommodation search API (RapidAPI Hotels.com provider)
RAPIDAPI_KEY=your_rapidapi_key

# Legacy/Future: not used by the current accommodation service.
# HOTELBEDS_API_KEY=your_hotelbeds_api_key
# HOTELBEDS_API_SECRET=your_hotelbeds_secret

# Email
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_NAVER_USER=your_naver_email
EMAIL_NAVER_PASS=your_naver_smtp_password
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_SECURE=true

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Gemini AI / RAG
GEMINI_API_KEY=your_gemini_api_key
CHAT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# ── 외부 검색 API ─────────────────────────────────────────
# https://rapidapi.com 에서 발급
RAPIDAPI_KEY=your_rapidapi_key

# ── 환율 API ──────────────────────────────────────────────
# https://www.exchangerate-api.com/ 에서 발급
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# ── Tavily 웹 검색 (MCP Agent용) ──────────────────────────
# https://app.tavily.com 에서 발급
# Tavily web search for MCP
TAVILY_API_KEY=your_tavily_api_key

# MySQL.
# Local npm run dev with Docker MySQL uses localhost:3307.
# docker compose backend overrides MYSQL_HOST=mysql and MYSQL_PORT=3306.
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=tripuser
MYSQL_PASSWORD=trippassword
MYSQL_DATABASE=trip_helper

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=travel_knowledge
VECTOR_SIZE=3072

# Server
PORT=3001
BACKEND_URL=http://localhost:3001

# Comma-separated allowed frontend origins for CORS.
FRONTEND_URLS=http://localhost:5173

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# Kakao login
# Use the Kakao Developers REST API key, not the JavaScript key.
KAKAO_CLIENT_ID=restapi키 값
KAKAO_CLIENT_SECRET=클라이언트 시크릿 키 값
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
